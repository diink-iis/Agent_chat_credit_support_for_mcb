%% Граф агента (Уровень 2) — маршрутизация с условиями.
%% Источник истины: agent/graph.py (route_after_classify / route_after_query_db).
%% Вставить в слайд через mermaid.live или импортом в draw.io (Insert -> Mermaid).

graph TD
    START([Запрос клиента]) --> classify

    classify -->|"триггер эскалации<br/>ПРИОРИТЕТ п.4.1"| escalate
    classify -->|"transactional<br/>needs_db=true"| query_db
    classify -->|"info / edge_conflict<br/>needs_rag=true"| retrieve_rag
    classify -->|"offtopic / манипуляция<br/>без источников"| generate_answer

    query_db -->|"нужна нормативка"| retrieve_rag
    query_db -->|"access_denied / хватает данных клиента"| generate_answer

    retrieve_rag --> generate_answer

    generate_answer --> ENDA([Ответ + источники])
    escalate --> ENDE([Пакет оператору ≤500])

    classify -. "детерминированный предохранитель:<br/>чужие данные / представитель / prompt injection<br/>→ suspicious, в обход query_db" .-> escalate

    subgraph sec [Ключевые свойства]
      direction LR
      n1["multi-turn: checkpointer хранит<br/>историю между ходами"]
      n2["грунтинг: ответ строго по источникам;<br/>нет источников → честная деградация"]
      n3["retrieve_rag: ретрай транзиентных<br/>сбоев эмбеддингов перед деградацией"]
    end

    classDef node fill:#d5e8d4,stroke:#82b366;
    classDef esc fill:#ffe6cc,stroke:#d79b00;
    class classify,query_db,retrieve_rag,generate_answer node;
    class escalate esc;
